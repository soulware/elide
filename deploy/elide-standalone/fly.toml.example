# Elide coordinator on Fly.io, standalone — a private app (no public service),
# reachable over 6PN at <app>.internal. Template: ./launch.sh generates fly.toml
# (gitignored) from this; or copy it yourself, fill app/primary_region and
# DATA_BUCKET, set the AWS_* secrets, then `fly deploy` from this directory.
# See README.md.

app = "elide-coord-standalone"
primary_region = "iad"

[build]
  dockerfile = "Dockerfile"
  [build.args]
    # DATA_BUCKET: the Tigris bucket the AWS_* keypair has read/write on; baked
    # into coord.toml [store].bucket.
    DATA_BUCKET = "elide"

# Coordinator state — index/, cache/, credentials/, keys — lives here on the
# volume so it survives redeploys (matches data_dir in coord.toml). The first
# deploy creates the volume at initial_size. The Tigris read/write keypair is
# supplied as secrets, not here:
#   fly secrets set AWS_ACCESS_KEY_ID=… AWS_SECRET_ACCESS_KEY=…
[mounts]
  source = "elide_data"
  destination = "/data"
  initial_size = "10gb"

# Serverless-off: keep one instance up so the served volumes stay live. The
# coordinator serves block devices over ublk (the image loads `ublk_drv`; Fly
# machines grant CAP_SYS_MODULE), so size for volume I/O.
[[vm]]
  size = "shared-cpu-1x"
  memory = "1024mb"

# No [http_service] and no tcp [checks]: the app is private and the coordinator
# binds no TCP port — its control plane is a UDS and ublk is local.
