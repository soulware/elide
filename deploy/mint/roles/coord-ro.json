{
  "Version": "2012-10-17",
  "Statement": [{
    "Sid": "ControlPlaneReadOnly",
    "Effect": "Allow",
    "Action": ["s3:GetObject"],
    "Resource": [
      "arn:aws:s3:::elide/names/*",
      "arn:aws:s3:::elide/coordinators/*",
      "arn:aws:s3:::elide/events/*",
      "arn:aws:s3:::elide/meta/*"
    ],
    "Condition": {
      "DateLessThan": {"aws:CurrentTime": "{{mint.expiry}}"}
    }
  }]
}
