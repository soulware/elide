{
  "Version": "2012-10-17",
  "Statement": [{
    "Sid": "ControlPlaneReadOnly",
    "Effect": "Allow",
    "Action": ["s3:GetObject"],
    "Resource": [
      "arn:aws:s3:::{{build.bucket}}/names/*",
      "arn:aws:s3:::{{build.bucket}}/coordinators/*",
      "arn:aws:s3:::{{build.bucket}}/events/*",
      "arn:aws:s3:::{{build.bucket}}/meta/*"
    ],
    "Condition": {
      "DateLessThan": {"aws:CurrentTime": "{{mint.expiry}}"}
    }
  }]
}
