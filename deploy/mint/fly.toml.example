# mint-for-elide on Fly.io — a private app (no public service): reachable over
# 6PN at <app>.internal:8085. Template: copy to fly.toml (gitignored), fill
# app/primary_region and the build args, then `fly deploy` from this directory.
# See README.md § Fly.io deployment.

app = "mint-for-elide"
primary_region = "iad"

[build]
  dockerfile = "Dockerfile"
  [build.args]
    # MINT_REF: lockstep mint source ref. DATA_BUCKET: the volume-data bucket
    # baked into the role ARNs (must equal the coordinator's [store].bucket); it
    # also becomes mint's own admin-store bucket (_mint/* under a distinct
    # prefix) unless STORE_BUCKET overrides it.
    MINT_REF = "93ffda83e69c17e5572ce0104ae8c5d84e353d5e"
    DATA_BUCKET = "elide"
    # STORE_BUCKET = "mint-admin"   # set only to isolate mint's _mint/* in its own bucket

[env]
  RUST_LOG = "info"
  # BRIDGE_AUTH = "1"   # expose the demo auth issuer on 6PN :8086 so an off-Fly
  #                     # coordinator can enroll (demo-tier; see README § VM-
  #                     # coordinator enrollment). Unset = auth stays in-container.

# Keyring + sealed surface + invite nonce + demo secrets live here, on the
# volume, so they survive redeploys (matches data_dir in fly/config.head.toml).
[mounts]
  source = "mint_data"
  destination = "/data"

# Serverless-off: keep one instance up so the keyring and seal stay live.
[[vm]]
  size = "shared-cpu-1x"
  memory = "256mb"

# No [http_service]: the app is private. The demo auth issuer is off the network
# entirely (in-container UDS); the mint plane is 6PN-only.
[checks]
  [checks.mint]
    type = "tcp"
    port = 8085
    interval = "15s"
    timeout = "2s"
    grace_period = "10s"
